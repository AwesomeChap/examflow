{
  "name": "examflow",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "examflow",
      "version": "0.0.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/backend": {
      "name": "@examflow/backend",
      "version": "0.0.0"
    },
    "apps/frontend": {
      "name": "@examflow/frontend",
      "version": "0.0.0"
    },
    "node_modules/@examflow/backend": {
      "resolved": "apps/backend",
      "link": true
    },
    "node_modules/@examflow/frontend": {
      "resolved": "apps/frontend",
      "link": true
    },
    "node_modules/@examflow/shared-types": {
      "resolved": "packages/shared-types",
      "link": true
    },
    "packages/shared-types": {
      "name": "@examflow/shared-types",
      "version": "0.0.0"
    }
  }
}
